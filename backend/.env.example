# DensityX AI Backend Configuration
# Copy this file to .env and update values for your deployment

# ============= SERVER CONFIGURATION =============
HOST=0.0.0.0
PORT=8003
RELOAD=False
DEBUG=False

# ============= FIREBASE CONFIGURATION =============
# Firebase Service Account Credentials (JSON as string)
# Get this from Firebase Console → Project Settings → Service Accounts
# Option 1: Paste entire JSON as single line (recommended for production)
# FIREBASE_CREDENTIALS_JSON='{"type":"service_account","project_id":"your-project-id",...}'

# Option 2: Or set path to credentials file (for development only)
# FIREBASE_CREDENTIALS_PATH="firebase-credentials.json"

# Firebase Database URL
# Format: https://your-project-id.firebaseio.com
FIREBASE_DATABASE_URL="https://your-project-id.firebaseio.com"

# Firebase Storage Bucket
# Format: your-project-id.appspot.com
FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"

# ============= VENUE CONFIGURATION =============
# Venue center (latitude, longitude) — anchored in Anna Nagar, Chennai
VENUE_CENTER_LAT=13.0850
VENUE_CENTER_LNG=80.2101
# Simulation area radius (in kilometers).
# Higher values expand coverage across a larger geographic area without
# changing point count or cluster density.
# The value is converted to latitude/longitude degrees based on venue location.
# Examples:
#   1.5  = tight coverage (~1.5 km radius)
#   4.0  = medium-large venue (~4 km radius, default)
#   5.0  = large venue (~5 km radius, e.g., Santosh to VR Mall)
VENUE_RADIUS_KM=4.0
# Optional extra margin (meters) added on top of the radius bounds
AREA_MARGIN_METERS=200

# ============= SIMULATION CONFIGURATION =============
BASE_CROWD_SIZE=200
UPDATE_INTERVAL_SECONDS=2
SURGE_EXTRA=500
# Hotspot simulation parameters
HOTSPOT_FRACTION=0.3
HOTSPOT_DELTA=0.00003

# ============= DBSCAN CLUSTERING PARAMETERS =============
DBSCAN_EPS_METERS=25
DBSCAN_MIN_SAMPLES=15
CLUSTER_ALERT_THRESHOLD=120
# HIGH_RISK_MIN_SIZE=10  # used by future extensions

# DBSCAN Detection Interval
DBSCAN_INTERVAL_SECONDS=10

# ============= LOGGING =============
LOG_LEVEL=INFO
